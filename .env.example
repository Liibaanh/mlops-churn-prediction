# Copy to .env and fill in your values. Never commit .env to git.


# Come back to this file
# MLflow
MLFLOW_TRACKING_URI=./mlruns      # Local tracking (no server needed)
MLFLOW_EXPERIMENT_NAME=churn-prediction

# Model serving
MODEL_NAME=churn_model
MODEL_VERSION=1
API_HOST=0.0.0.0
API_PORT=8000

# Databricks (for production deployment)
DATABRICKS_HOST=https://ditt-workspace.azuredatabricks.net
DATABRICKS_TOKEN=My_token